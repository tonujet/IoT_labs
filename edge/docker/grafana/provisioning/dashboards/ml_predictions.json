      "title": "Model Comparison (latest metrics)",
      "datasource": { "type": "postgres", "uid": "postgres_ds" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 5 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "mae" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 3 }] },
