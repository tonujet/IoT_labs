          { "matcher": { "id": "byName", "options": "MovingAverage" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT created_at AS time, AVG(mae) AS \"LinearRegression\" FROM predictions WHERE field_name = 'temperature' AND model_name = 'LinearRegression' AND $__timeFilter(created_at) GROUP BY created_at ORDER BY created_at;",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
