          { "matcher": { "id": "byName", "options": "MovingAverage" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT timestamp AS time, pm25 AS actual FROM processed_agent_data WHERE $__timeFilter(timestamp) AND pm25 IS NOT NULL ORDER BY timestamp;",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT prediction_timestamp AS time, predicted_value AS \"LinearRegression\" FROM predictions WHERE field_name = 'pm25' AND model_name = 'LinearRegression' AND $__timeFilter(prediction_timestamp) ORDER BY prediction_timestamp;",
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT prediction_timestamp AS time, predicted_value AS \"MovingAverage\" FROM predictions WHERE field_name = 'pm25' AND model_name = 'MovingAverage' AND $__timeFilter(prediction_timestamp) ORDER BY prediction_timestamp;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Temperature — MAE over time",
      "datasource": { "type": "postgres", "uid": "postgres_ds" },
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "always", "pointSize": 4 } },
        "overrides": [
