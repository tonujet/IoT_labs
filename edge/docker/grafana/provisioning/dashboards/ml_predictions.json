{
  "uid": "ml-predictions",
  "title": "ML Predictions",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now+5m" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Temperature — Actual vs Predicted",
      "datasource": { "type": "postgres", "uid": "postgres_ds" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "always", "pointSize": 4 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "actual" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "LinearRegression" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] },
          { "matcher": { "id": "byName", "options": "MovingAverage" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT timestamp AS time, temperature AS actual FROM processed_agent_data WHERE $__timeFilter(timestamp) AND temperature IS NOT NULL ORDER BY timestamp;",
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT prediction_timestamp AS time, predicted_value AS \"LinearRegression\" FROM predictions WHERE field_name = 'temperature' AND model_name = 'LinearRegression' AND $__timeFilter(prediction_timestamp) ORDER BY prediction_timestamp;",
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT prediction_timestamp AS time, predicted_value AS \"MovingAverage\" FROM predictions WHERE field_name = 'temperature' AND model_name = 'MovingAverage' AND $__timeFilter(prediction_timestamp) ORDER BY prediction_timestamp;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PM2.5 — Actual vs Predicted",
      "datasource": { "type": "postgres", "uid": "postgres_ds" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "µg/m³", "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true, "showPoints": "always", "pointSize": 4 } },
        "overrides": [
