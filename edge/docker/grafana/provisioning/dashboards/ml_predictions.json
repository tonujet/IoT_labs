      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres_ds" },
          "rawSql": "SELECT DISTINCT ON (field_name, model_name) field_name, model_name, mae, rmse, created_at FROM predictions ORDER BY field_name, model_name, created_at DESC;",
